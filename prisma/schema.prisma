generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id        String   @id @default(cuid())
  name      String
  address   String   @default("")
  units     String   @default("imperial")
  scale     String   @default("")
  floors    Int      @default(1)
  status    String   @default("uploaded")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pages     Page[]
  items     TakeoffItem[]
  metadata  String   @default("{}")
}

model Page {
  id             String  @id @default(cuid())
  projectId      String
  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pageNumber     Int
  imagePath      String
  classification String  @default("unknown")
  confidence     Float   @default(0)
  rawExtraction  String  @default("{}")
  userOverrides  String  @default("{}")
}

model TakeoffItem {
  id           String  @id @default(cuid())
  projectId    String
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category     String
  description  String
  quantity     Float
  unit         String
  wasteFactor  Float   @default(0)
  totalWithWaste Float @default(0)
  sourcePageId String  @default("")
  confidence   Float   @default(0)
  userEdited   Boolean @default(false)
  notes        String  @default("")
}
